# =============================================================================
# Visual Studio
# =============================================================================
.vs/
*.user
*.suo

# =============================================================================
# JetBrains IDEs
# =============================================================================
.idea/

# =============================================================================
# Build Outputs
# =============================================================================
x64/
Debug/
Release/

# =============================================================================
# C++/MSVC Intermediate Files
# =============================================================================
*.obj
*.pdb
*.ilk
*.idb
*.pch
*.ipch
ipch/
*.log
*.tlog
*.recipe
*.lastbuildstate

# =============================================================================
# Binaries
# =============================================================================
*.exe
*.dll
*.lib
*.exp

# =============================================================================
# DirectX / Shaders
# =============================================================================
*.cso
*.hlsl.h

# =============================================================================
# Windows
# =============================================================================
Thumbs.db
Desktop.ini

# =============================================================================
# Misc
# =============================================================================
*.bak
*.tmp

# vcpkg
vcpkg_installed/

# ImGui
imgui.ini

# Claude Code settings
# settings.json is shared via the repo; settings.local.json holds per-user overrides and must not be tracked.
.claude/settings.local.json

# =============================================================================
# 3D Model Assets
# =============================================================================
# Exclude binary model files by default (game-final assets should not bloat git history).
# Samples/ holds Khronos sample assets used for validation and is tracked.
Application/Assets/Models/*.glb
Application/Assets/Models/*.gltf
Application/Assets/Models/*.fbx
Application/Assets/Models/*.bin
!Application/Assets/Models/Samples/

# =============================================================================
# Runtime Caches (BACA framework)
# =============================================================================
# Per-build cooked artifacts under Application/.cache/{Models,Shaders,...}.
Application/.cache/
