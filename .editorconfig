root = true

[*]
charset = utf-8
end_of_line = crlf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cpp,h,hpp,inl,ixx}]
indent_style = space
indent_size = 4
charset = utf-8-bom

[*.{hlsl,hlsli}]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.json]
indent_style = space
indent_size = 2

[*.{vcxproj,slnx,xml,props,targets,filters}]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2
